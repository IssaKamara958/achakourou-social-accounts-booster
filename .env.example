# ============================================================================
# ACHAKOUROU SOCIAL ACCOUNTS BOOSTER (ACAB)
# Configuration Environment Variables
# ============================================================================

# ============================================================================
# Supabase Configuration
# ============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anonymous_key_here

# ============================================================================
# OAuth Configuration - Facebook
# ============================================================================
# Obtenir depuis: https://developers.facebook.com/apps
VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_FACEBOOK_APP_SECRET=your_facebook_app_secret

# ============================================================================
# OAuth Configuration - Instagram Business
# ============================================================================
# Obtenir depuis: https://developers.instagram.com/apps
VITE_INSTAGRAM_APP_ID=your_instagram_app_id
VITE_INSTAGRAM_APP_SECRET=your_instagram_app_secret

# ============================================================================
# OAuth Configuration - TikTok
# ============================================================================
# Obtenir depuis: https://developers.tiktok.com/apps
VITE_TIKTOK_CLIENT_KEY=your_tiktok_client_key
VITE_TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ============================================================================
# AI/ML Configuration
# ============================================================================
# OpenAI API Configuration
VITE_AI_API_URL=https://api.openai.com/v1
VITE_OPENAI_API_KEY=your_openai_api_key

# Ou alternative (ex: Azure OpenAI)
# VITE_AI_API_URL=https://your-resource.openai.azure.com/
# VITE_AI_DEPLOYMENT_ID=your_deployment_id

# ============================================================================
# Synchronization Configuration
# ============================================================================
# Secret key for cron job authentication
SYNC_CRON_SECRET=your_secure_random_secret_key_for_cron_jobs

# Sync intervals (en secondes)
SYNC_INTERVAL_POSTS=3600       # Sync posts every hour
SYNC_INTERVAL_ANALYTICS=7200   # Sync analytics every 2 hours
SYNC_INTERVAL_COMMENTS=1800    # Sync comments every 30 minutes

# ============================================================================
# Supabase Service Role Key (Backend Only)
# ============================================================================
# ⚠️ NEVER expose this in frontend!
# Utilisé uniquement sur le serveur et les Edge Functions
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================================================
# Netlify Configuration
# ============================================================================
NETLIFY_AUTH_TOKEN=your_netlify_token
NETLIFY_SITE_ID=your_site_id

# ============================================================================
# Application Configuration
# ============================================================================
# App Name
VITE_APP_NAME=ACAB - Achakourou Social Accounts Booster

# Redirect URLs (for OAuth callbacks)
VITE_FACEBOOK_CALLBACK_URL=http://localhost:5000/auth/callback/facebook
VITE_INSTAGRAM_CALLBACK_URL=http://localhost:5000/auth/callback/instagram
VITE_TIKTOK_CALLBACK_URL=http://localhost:5000/auth/callback/tiktok

# Production URLs
VITE_PRODUCTION_URL=https://acab.achakourou.com
VITE_PRODUCTION_FACEBOOK_CALLBACK=https://acab.achakourou.com/auth/callback/facebook
VITE_PRODUCTION_INSTAGRAM_CALLBACK=https://acab.achakourou.com/auth/callback/instagram
VITE_PRODUCTION_TIKTOK_CALLBACK=https://acab.achakourou.com/auth/callback/tiktok

# ============================================================================
# Analytics & Monitoring
# ============================================================================
# Sentry (error tracking)
VITE_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_token

# LogRocket (session replay)
VITE_LOGROCKET_ID=your_logrocket_id

# ============================================================================
# Feature Flags
# ============================================================================
VITE_ENABLE_AI_OPTIMIZATION=true
VITE_ENABLE_PWA=true
VITE_ENABLE_BACKGROUND_SYNC=true
VITE_ENABLE_NOTIFICATIONS=true

# ============================================================================
# Rate Limiting
# ============================================================================
# Requests per minute per user
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# Logging
# ============================================================================
VITE_LOG_LEVEL=info  # debug, info, warn, error
VITE_ENABLE_CONSOLE_LOGS=true

# ============================================================================
# Development / Testing
# ============================================================================
# Pour les tests locaux
VITE_MOCK_OAUTH=false
VITE_MOCK_API=false
VITE_USE_LOCAL_SUPABASE=false

# ============================================================================
# Email Configuration (for notifications & alerts)
# ============================================================================
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@achakourou.com

# ============================================================================
# Storage Configuration
# ============================================================================
# S3 pour les uploads de médias
AWS_S3_BUCKET=acab-uploads
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=your_aws_key
AWS_S3_SECRET_ACCESS_KEY=your_aws_secret

# ============================================================================
# Security
# ============================================================================
# JWT Secret (si nécessaire)
JWT_SECRET=your_super_secure_jwt_secret_key

# CORS allowed origins
VITE_CORS_ORIGINS=http://localhost:5000,https://acab.achakourou.com

# ============================================================================
# Notes Importantes
# ============================================================================
# 1. Ne JAMAIS commiter ce fichier avec les vraies valeurs
# 2. Utiliser des secrets différents pour dev/staging/production
# 3. Rotater les clés API régulièrement
# 4. Utiliser les Secrets Manager (Netlify, Supabase, AWS Secrets Manager)
# 5. Activer 2FA sur tous les comptes de développeur
