# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USER=achakourou
DB_PASSWORD=achakourou_password
DB_DATABASE=achakourou_social
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}?schema=public"

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET="achakourou-super-secret-key-that-is-long-enough"

# Encryption
ENCRYPTION_KEY="a_32_byte_long_hexadecimal_secret_key_for_encryption_!@#$"

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=social-booster
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}

# OpenAI API Key
OPENAI_API_KEY="sk-proj-..."

# OAuth - Facebook
FB_CLIENT_ID="your_facebook_client_id"
FB_CLIENT_SECRET="your_facebook_client_secret"

# OAuth - Instagram (via Facebook)
IG_CLIENT_ID="your_instagram_client_id"
IG_CLIENT_SECRET="your_instagram_client_secret"

# OAuth - TikTok
TTK_CLIENT_KEY="your_tiktok_client_key"
TTK_CLIENT_SECRET="your_tiktok_client_secret"
